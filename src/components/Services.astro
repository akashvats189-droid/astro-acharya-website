<section class="services" id="services">
  <div class="services-container">
    <h2>Why Choose Astro Acharya?</h2>
    <div class="features">
      <div class="feature">
        <div class="feature-icon">🎯</div>
        <h3>Accurate Readings</h3>
        <p>Precise astrological calculations based on Vedic principles</p>
      </div>
      <div class="feature">
        <div class="feature-icon">👨‍🏫</div>
        <h3>Expert Practitioners</h3>
        <p>15+ years of experience in celestial guidance</p>
      </div>
      <div class="feature">
        <div class="feature-icon">🤝</div>
        <h3>Personal Care</h3>
        <p>Tailored solutions for your unique cosmic blueprint</p>
      </div>
    </div>
  </div>
</section>

<style>
  .services {
    padding: 4rem 2rem;
    background: linear-gradient(135deg, #0f3460 0%, #16213e 100%);
  }

  .services-container {
    max-width: 1000px;
    margin: 0 auto;
  }

  .services h2 {
    font-size: 2.5rem;
    text-align: center;
    margin-bottom: 3rem;
    color: #667eea;
  }

  .features {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 2rem;
  }

  .feature {
    background: #1a1a2e;
    padding: 2rem;
    border-radius: 10px;
    text-align: center;
    border: 1px solid #667eea;
    transition: transform 0.3s, box-shadow 0.3s;
  }

  .feature:hover {
    transform: translateY(-5px);
    box-shadow: 0 10px 30px rgba(102, 126, 234, 0.2);
  }

  .feature-icon {
    font-size: 3rem;
    margin-bottom: 1rem;
  }

  .feature h3 {
    color: #764ba2;
    margin-bottom: 0.5rem;
    font-size: 1.3rem;
  }

  .feature p {
    color: #aaa;
    line-height: 1.6;
  }
</style>