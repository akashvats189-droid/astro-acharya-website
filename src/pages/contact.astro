---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Contact Us - Astro Acharya">
  <section class="contact-section">
    <div class="container">
      <h1>Get in Touch</h1>
      <p class="intro">Have questions? We'd love to hear from you!</p>
      
      <div class="contact-content">
        <div class="contact-form">
          <form>
            <div class="form-group">
              <label for="name">Full Name</label>
              <input type="text" id="name" name="name" required />
            </div>
            
            <div class="form-group">
              <label for="email">Email Address</label>
              <input type="email" id="email" name="email" required />
            </div>
            
            <div class="form-group">
              <label for="phone">Phone Number</label>
              <input type="tel" id="phone" name="phone" />
            </div>
            
            <div class="form-group">
              <label for="service">Service Interested In</label>
              <select id="service" name="service">
                <option value="">Select a service</option>
                <option value="birth-chart">Birth Chart Analysis</option>
                <option value="horoscope">Horoscope Reading</option>
                <option value="gemstone">Gemstone Guidance</option>
                <option value="compatibility">Relationship Compatibility</option>
                <option value="vastu">Vastu Consultation</option>
                <option value="career">Career Guidance</option>
              </select>
            </div>
            
            <div class="form-group">
              <label for="message">Message</label>
              <textarea id="message" name="message" rows="5" required></textarea>
            </div>
            
            <button type="submit" class="btn btn-primary">Send Message</button>
          </form>
        </div>
        
        <div class="contact-info">
          <div class="info-card">
            <h3>📍 Location</h3>
            <p>123 Celestial Road<br/>Astrology City, AC 12345<br/>India</p>
          </div>
          
          <div class="info-card">
            <h3>📞 Contact</h3>
            <p>Phone: +91 98765 43210<br/>Email: info@astroacharya.com<br/>WhatsApp: +91 98765 43210</p>
          </div>
          
          <div class="info-card">
            <h3>🕐 Hours</h3>
            <p>Monday - Friday: 10:00 AM - 6:00 PM<br/>Saturday: 10:00 AM - 4:00 PM<br/>Sunday: Closed</p>
          </div>
          
          <div class="info-card">
            <h3>🌐 Follow Us</h3>
            <p>
              <a href="#">Facebook</a> | 
              <a href="#">Instagram</a> | 
              <a href="#">Twitter</a>
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>
</Layout>

<style>
  .contact-section {
    padding: 4rem 2rem;
  }

  .container {
    max-width: 1000px;
    margin: 0 auto;
  }

  .contact-section h1 {
    font-size: 3rem;
    text-align: center;
    margin-bottom: 0.5rem;
    background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
  }

  .intro {
    text-align: center;
    color: #aaa;
    font-size: 1.1rem;
    margin-bottom: 3rem;
  }

  .contact-content {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 3rem;
  }

  .contact-form {
    background: #0f3460;
    padding: 2rem;
    border-radius: 10px;
    border: 1px solid #667eea;
  }

  .form-group {
    margin-bottom: 1.5rem;
  }

  .form-group label {
    display: block;
    margin-bottom: 0.5rem;
    color: #667eea;
    font-weight: 500;
  }

  .form-group input,
  .form-group select,
  .form-group textarea {
    width: 100%;
    padding: 0.8rem;
    background: #1a1a2e;
    border: 1px solid #667eea;
    border-radius: 5px;
    color: #eee;
    font-family: inherit;
  }

  .form-group input:focus,
  .form-group select:focus,
  .form-group textarea:focus {
    outline: none;
    border-color: #764ba2;
    box-shadow: 0 0 5px rgba(118, 75, 162, 0.3);
  }

  .contact-info {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
  }

  .info-card {
    background: #0f3460;
    padding: 1.5rem;
    border-radius: 10px;
    border: 1px solid #667eea;
  }

  .info-card h3 {
    color: #667eea;
    margin-bottom: 0.5rem;
    font-size: 1.2rem;
  }

  .info-card p {
    color: #bbb;
    line-height: 1.6;
  }

  .info-card a {
    color: #764ba2;
    text-decoration: none;
  }

  .info-card a:hover {
    text-decoration: underline;
  }

  @media (max-width: 768px) {
    .contact-content {
      grid-template-columns: 1fr;
    }
  }
</style>